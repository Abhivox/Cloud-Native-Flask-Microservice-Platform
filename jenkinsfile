pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                git 'https://github.com/Abhivox/project.git'
            }
        }

        stage('Build Image') {
            steps {
                sh 'docker build -t flask-app:latest .'
            }
        }

        stage('Load to Kind') {
            steps {
                sh 'kind load docker-image flask-app:latest --name devops'
            }
        }

        stage('Deploy') {
            steps {
                sh 'kubectl apply -f k8s/'
            }
        }
    }
}
